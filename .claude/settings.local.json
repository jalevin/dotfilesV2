{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(tree:*)",
      "Bash(comm:*)",
      "Bash(comm -13:*)",
      "WebSearch",
      "Bash(nix flake show:*)",
      "Bash(python3:*)",
      "Bash(defaults read:*)",
      "WebFetch(domain:github.com)",
      "Bash(awk '{:*)",
      "Bash(brew search *)",
      "Bash(brew deps *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "anthropic-docs",
    "github",
    "fetch"
  ]
}
